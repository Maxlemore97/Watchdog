{
  "name": "watchdog",
  "version": "0.6.0",
  "description": "Pre-install security analyzer: OSV CVE lookup + LLM source review for packages and Claude plugins. Single-binary Go port; install via watchdog-shim.",
  "author": {
    "name": "Maxlemore97",
    "email": "30655722+Maxlemore97@users.noreply.github.com",
    "url": "https://github.com/Maxlemore97"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pretool.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/prompt.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session.sh"
          }
        ]
      }
    ]
  }
}
